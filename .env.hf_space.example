# Hugging Face Space deployment template for this project.
# Copy to .env.hf_space.local (or source directly) and set only HF_TOKEN.

# Your target Space (from https://huggingface.co/spaces/keshaf/kesh_ai)
HF_SPACE_ID=keshaf/kesh_ai
HF_SPACE_PAGE_URL=https://huggingface.co/spaces/keshaf/kesh_ai
HF_SPACE_URL=https://keshaf-kesh-ai.hf.space

# Required inference/runtime variables for submission spec.
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Set this to a real token before deploying.
HF_TOKEN=hf_xxx_replace_me
